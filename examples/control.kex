type ParseError = InvalidFormat(String) | Overflow | EmptyInput

let check(s: String) -> Result<Bool, ParseError> do
  return Error(EmptyInput) if s.empty?
  return Ok(true)
end

let sign(n: Integer) -> String do
  if n > 0
    "positive"
  elif n < 0
    "negative"
  else
    "zero"
  end
end

main do
  IO.printLine(check(""))
  IO.printLine(sign(-3))
end
