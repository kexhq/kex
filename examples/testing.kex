# Testing — describe/it/assert, the stdlib's RSpec-style framework.
#
# Calls are parenthesized (`describe("name") do`, not `describe "name" do`)
# — the grammar has no support for a bare positional argument without
# parens. No `main do...end` wrapper is needed: a bare top-level expression
# like `describe(...) do ... end` is already wrapped into one by the parser.
#
# `before`/`Mock.*`/`using Test` and a `kex test` subcommand are sketched in
# docs/testing.md but not implemented yet — this example sticks to what's
# real today.

record User do
  name : String
  age : Int
end

make User do
  let greet -> String do
    "Hi, ${@name}!"
  end

  let adult? -> Bool do
    @age >= 18
  end
end

describe("Integer") do
  describe("even?/odd?") do
    it("identifies even numbers") do
      assert(4.even?)
      assert(0.even?)
      assert(!3.even?)
    end

    it("identifies odd numbers") do
      assert(3.odd?)
      assert(!4.odd?)
    end
  end
end

describe("User") do
  let sampleUser = User { name: "Alice", age: 30 }

  describe("greet") do
    it("greets by name") do
      assert(sampleUser.greet == "Hi, Alice!")
    end
  end

  describe("adult?") do
    it("returns true for age >= 18") do
      assert(sampleUser.adult?)
    end

    it("returns false for age < 18") do
      let child = User { name: "Kid", age: 10 }
      assert(!child.adult?)
    end
  end
end
