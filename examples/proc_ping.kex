# kex: no-check
# Layer-1 smoke test for BEAM processes: spawn + send + receive round-trip.
# A child process waits for :ping messages and replies :pong to the sender.

foul pingServer do
  spawn do
    loop
      receive do |sender|
        :ping -> sender.send(:pong)
      end
    end
  end
end

main do
  let server = pingServer()
  server.send(:ping)
  receive do
    :pong -> IO.printLine("pong")
  end
end
