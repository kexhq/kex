make [X] do
  # `head` is a new method added to lists (`rest` already comes from the
  # sealed stdlib, so it isn't redefined here).
  head :> X?
  let head(@[]) = None
  let head(@[x | _]) = Just(x)
end

main do
  let list = [1, 2, 3]
  IO.printLine(list.head)   # same as: head(list)
  IO.printLine([].head)     # same as: head([])

  IO.printLine(list.rest)
end
