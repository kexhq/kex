# UFCS: value.f(arg) is the same as f(value, arg).
# That means plain functions chain like methods.

main do
  let nums = [1, 2, 3, 4, 5, 6]

  let result = nums
    .filter(&.even?)            # [2, 4, 6]
    .map { |n| n * n }          # [4, 16, 36]
    .sum                        # 56

  IO.printLine(result.to(String).or(""))
end
