# Functions and recursion
# Expected output:
# 42
# 7
# 120
# 55

let double(n: Int) = n * 2
let add(a: Int, b: Int) = a + b

let factorial(0) = 1
let factorial(n: Int) = n * factorial(n - 1)

let fib(0) = 0
let fib(1) = 1
let fib(n: Int) = fib(n - 1) + fib(n - 2)

main do
  IO.printLine(double(21))
  IO.printLine(add(3, 4))
  IO.printLine(factorial(5))
  IO.printLine(fib(10))
end
