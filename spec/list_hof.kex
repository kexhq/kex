main do
  # sum — integers
  IO.printLine([1, 2, 3, 4, 5].sum)

  # sum — floats
  IO.printLine([1.5, 2.5, 3.0].sum)

  # min / max return Optional
  IO.printLine([3, 1, 4, 1, 5].min)
  IO.printLine([3, 1, 4, 1, 5].max)
  IO.printLine([].min)
  IO.printLine([].max)

  # flatMap
  IO.printLine([[1, 2], [3, 4], [5]].flatMap { |xs| xs })
  IO.printLine([1, 2, 3].flatMap { |n| [n, n * 10] })
  IO.printLine(["hello", "world"].flatMap { |s| s.filter(&alpha?) })
end
