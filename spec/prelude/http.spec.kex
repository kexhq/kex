  before { Mock.Http.start() }
  after { Mock.Http.stop() }

  it("returns the staged response for PUT") do
    Mock.Http.respond(200, "updated")
    let result = Http.put("https://example.com/items/1", "{\"name\":\"new\"}")
    match result do
      Ok(resp) -> do
        assert(resp.status == 200)
        assert(resp.body == "updated")
      end
      Error(_) -> assert(false, "expected Ok")
