describe("Http.options — mocked") do
  before { Mock.Http.start() }
  after { Mock.Http.stop() }

  it("returns the staged response for OPTIONS") do
    Mock.Http.respond(200, "", { "Allow": "GET, POST" })
    let result = Http.options("https://example.com")
    match result do
      Ok(resp) -> assert(resp.status == 200)
      Error(_) -> assert(false, "expected Ok")
    end
  end
end

describe("Mock.Http — headers") do
  before { Mock.Http.start() }
  after { Mock.Http.stop() }

  it("respond with custom headers stores them") do
    Mock.Http.respond(200, "body", { "X-Custom": "hello" })
    let result = Http.get("https://example.com")
    match result do
      Ok(resp) -> assert(resp.headers.get("X-Custom") == Just("hello"))
      Error(_) -> assert(false, "expected Ok")
    end
  end

  it("respond without headers defaults to empty map") do
    Mock.Http.respond(200, "body")
    let result = Http.get("https://example.com")
    match result do
      Ok(resp) -> assert(resp.headers.empty?)
      Error(_) -> assert(false, "expected Ok")
    end
  end
end

describe("Mock.Http — error details") do
  before { Mock.Http.start() }
  after { Mock.Http.stop() }

  it("error has kind and message when queue is empty") do
    let result = Http.get("https://example.com")
    match result do
      Ok(_) -> assert(false, "expected Error")
      Error(e) -> do
        assert(e.kind == "mock")
        assert(e.message == "no responses staged")
      end
    end
  end
end
