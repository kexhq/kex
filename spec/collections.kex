# Collections and higher-order functions
# Expected output:
# [2, 4, 6, 8, 10]
# [2, 4]
# 15
# 5
# 1
# [1, 2, 3, 4, 5, 6]
# [1, 2, 3, 4, 5]
# hello, world, kex
# true
# true
# false
# olleh
# HI
# hi

let even?(n: Int) = n.modulo(2) == 0

main do
  let nums = [1, 2, 3, 4, 5]

  IO.printLine(nums.map { |x| x * 2 })
  IO.printLine(nums.filter(&even?))
  IO.printLine(nums.reduce(0) { |acc, x| acc + x })
  IO.printLine(nums.length)
  IO.printLine(nums.first)
  IO.printLine(nums.push(6))
  IO.printLine(nums.sort)
  IO.printLine(["hello", "world", "kex"].join(", "))
  IO.printLine(nums.any? { |x| x > 4 })
  IO.printLine(nums.all? { |x| x > 0 })
  IO.printLine(nums.all? { |x| x > 3 })
  IO.printLine("hello".reverse)
  IO.printLine("hi".upcase)
  IO.printLine("HI".downcase)
end
