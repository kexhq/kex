# Variables, mutation, and interpolation
# Expected output:
# 8
# 3
# Hello, World!
# count = 3
# [1, 2, 3, 4, 5]

main do
  let x = 5 + 3
  IO.printLine(x)

  var count = 0
  count = count + 1
  count = count + 1
  count = count + 1
  IO.printLine(count)

  let name = "World"
  IO.printLine("Hello, ${name}!")
  IO.printLine("count = ${count}")

  var list = [1, 2, 3]
  list = list.push(4)
  list = list.push(5)
  IO.printLine(list)
end
