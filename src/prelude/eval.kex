# Sandboxed evaluation of Kex source code at runtime.
#
# Creates a fresh, isolated evaluator for each call — the caller's
# environment is never shared. Returns +Result<Any, String>+.
module Evaluator do
  # Evaluates a full Kex program string.
  run : String -> Result<Any, String>
  run : (String, EvaluatorOptions) -> Result<Any, String>

  # Evaluates a single Kex expression.
  expression : String -> Result<Any, String>
  expression : (String, EvaluatorOptions) -> Result<Any, String>
end

record EvaluatorOptions do
  allow : [Atom] = [:Math, :List, :String, :Integer, :Map, :Stream]
  modules : {String: {String: (Any -> Any)}} = {}
  maxSteps : Int = 1_000_000
  maxDepth : Int = 256
end
