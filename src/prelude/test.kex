# Kex ships a minimal RSpec-style testing DSL: +describe+, +it+, +before+,
# +after+, and assertion helpers. These are always in scope — no import needed.
#
# A test file typically looks like:
#
# @example
#   describe "arithmetic" do
#     it "adds numbers" do
#       assert(1 + 1 == 2)
#     end
#
#     it "multiplies numbers" do
#       assert(3 * 4 == 12, "expected 12")
#     end
#   end
#
# Run with:
#   kex my_test.kex
#
# Output uses ✓ / ✗ markers and nests by describe depth.

# Groups related test cases under a label. Calls the block immediately.
# +describe+ blocks may be nested. This is a foul function — it prints output.
#
# @param label [String]
# @param block [Block]
# @return [Unit]
#
# @example
#   describe "String" do
#     describe "count" do
#       it "returns character count" do
#         assert("hello".count == 5)
#       end
#     end
#   end
describe : String -> Block<Unit> -> Unit

# Defines a single test case. The block is run and any exception thrown
# inside it (typically a failed +assert+) marks the test failed without
# aborting the rest of the suite. This is a foul function — it prints output.
#
# @param label [String]
# @param block [Block]
# @return [Unit]
#
# @example
#   it "returns true for even numbers" do
#     assert(2.even?)
#     assert(!3.even?)
#   end
it : String -> Block<Unit> -> Unit

# Registers setup for the current group. +before { ... }+ and
# +before(:each) { ... }+ run before every test; +before(:all) { ... }+ runs
# once before the group's tests, following RSpec's scope convention.
before : Block<Unit> -> Unit

# Registers cleanup for the current group. +after { ... }+ defaults to +:each+;
# +after(:all) { ... }+ runs once when the group finishes. Cleanup is
# unconditional, and inner per-test hooks run before outer hooks.
after : Block<Unit> -> Unit

# Throws a runtime error if +value+ is falsy, failing the enclosing +it+.
# The optional +message+ is included in the failure output.
#
# @param value   [Bool]
# @param message [String]  (optional)
# @return [Bool]
#
# @example
#   assert(42 == 42)
#   assert("hello".count == 5, "count should be 5")
assert : Bool -> Bool

# Focused assertions are ordinary Kex stdlib functions layered on the primitive
# +assert+, so adding another helper does not require compiler or runtime work.
module Assert do
  let equal(actual, expected) = assert(actual == expected, "expected ${expected}, got ${actual}")
  let notEqual(actual, expected) = assert(actual != expected, "expected values to differ, both were ${actual}")

  let truthy(value) = assert(value, "expected a truthy value")
  let falsy(value) = assert(!value, "expected a falsy value")
  let some(value) = assert(value.some?, "expected Just, got ${value}")
  let none(value) = assert(value.none?, "expected None, got ${value}")
  let ok(value) = assert(value.ok?, "expected Ok, got ${value}")
  let error(value) = assert(value.error?, "expected Error, got ${value}")
end
